# Токен Telegram-бота від @BotFather
BOT_TOKEN=

# Ключ Anthropic API (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Твій особистий Telegram user_id (тільки ти матимеш доступ до команд керування)
ADMIN_USER_ID=

# ID групи/груп марафону, які бот має моніторити, через кому
# (якщо в тебе канал + окрема група обговорень, вкажи обидва ID через кому)
GROUP_CHAT_IDS=

# Через скільки годин без відповіді надсилати нагадування (за замовчуванням 6)
REMINDER_THRESHOLD_HOURS=6

# Часовий пояс для нагадувань, публікацій і щоденного дайджесту
TIMEZONE=Europe/London

# О котрій годині (за вказаним TIMEZONE) надсилати щоденний дайджест настроїв
DAILY_DIGEST_TIME=20:00

# Модель Claude для аналізу повідомлень
CLAUDE_MODEL=claude-sonnet-4-5

# Шлях до файлу SQLite бази даних
DB_PATH=marathon.db

# Скільки днів триває марафон (для валідації хештегів #деньN)
TASK_HASHTAG_DAYS=20
